{
  "expo": {
    "name": "LespassCleMobile",
    "slug": "LespassCleMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/lespasscles.png",
    "scheme": "lespassclemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/lespasscles.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/lespasscles.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/lespasscles.png"
    },
    "plugins": [
      "expo-router",
      "expo-barcode-scanner",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
