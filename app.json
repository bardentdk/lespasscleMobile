{
  "expo": {
    "name": "Lespasscle",
    "slug": "LespassCleMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/lespasscles.png",
    "scheme": "lespassclemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/lespasscles.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bardentdk.lespasscle"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/lespasscles.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.bardentdk.lespasscle"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/lespasscles.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "09a724c6-33ef-426c-9d87-0780d76244a9"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/09a724c6-33ef-426c-9d87-0780d76244a9"
    }
  }
}